# harness.env — single source of stack-specific configuration for every harness hook.
# Written by /forge at install time from its project scan; edit freely afterwards —
# forge upgrades NEVER overwrite this file. Plain KEY="VALUE" lines, sourced by bash.
#
# Empty value = that behavior is skipped gracefully (hooks fail open on missing config).

# Project identity (statusline prefix, session-start header)
PROJECT_NAME="{{PROJECT_NAME}}"

# Toolchain commands (run by update-status.sh / auto-test.sh / format-on-save.sh
# after edits to matching source files). Use the narrowest fast variants.
BUILD_CMD="{{BUILD_CMD}}"
TEST_CMD="{{TEST_CMD}}"
LINT_CMD="{{LINT_CMD}}"
FMT_CMD="{{FMT_CMD}}"

# Space-separated source-file extensions that trigger the post-edit toolchain hooks.
SRC_EXTS="{{SRC_EXTS}}"

# Space-separated directories that rm -rf must never target (block-dangerous-commands.sh).
PROTECTED_DIRS="{{PROTECTED_DIRS}}"

# Space-separated lockfile basenames that must never be hand-edited (protect-files.sh).
LOCKFILES="{{LOCKFILES}}"

# Comma-separated branches protected from direct/force push.
PROTECTED_BRANCHES="main,master"

# Space-separated manifest files hashed by the config-drift fingerprint (session-start.sh).
FINGERPRINT_FILES="{{FINGERPRINT_FILES}}"

# Optional: command that regenerates a dependency graph (stop.sh runs it non-fatally).
GRAPH_CMD="{{GRAPH_CMD}}"

# Hours since /loop last ran before capability-gate.sh treats it as overdue
# and blocks the next source edit until /loop runs again (0 = always overdue).
LOOP_OVERDUE_HOURS="24"
